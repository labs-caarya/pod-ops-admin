# Copy to .env and fill in values. VITE_* vars are baked into the build.
#
# AUTH: the admin dashboard uses the same backend user collection as the main
# frontend, but only `super_admin` / `["*"]` users can access this app.

# ── Temporary auth backend, incl. /api suffix ─────────────────────────────────
VITE_AUTH_API_URL=http://127.0.0.1:4000/api

# ── Ask Moksha agent (optional, chirag-ai LLM proxy base) ─────────────────────
# When set with a valid token, Ask Moksha calls chirag-ai; otherwise it answers
# from a small built-in knowledge base.
VITE_AI_URL=
