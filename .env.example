# Copy to .env and fill in values. VITE_* vars are baked into the build.
#
# AUTH (mirrors chirag-sandbox): Firebase phone OTP verifies the number, then we
# exchange it for a chronos-be JWT. chronos-be is used ONLY for this sign-in
# check — all feature data (research, rolodex, talent, jobs, partners) is this
# app's own and is stored locally until a dedicated backend is wired.

# ── Sign-in backend (chronos-be / moksha-be), incl. /api suffix ───────────────
VITE_CHRONOS_BE_URL=https://moksha-be-940979680786.europe-west2.run.app/api

# IAM pass gate. Set true in prod to require a CaaryaPass on chronos-be.
VITE_REQUIRE_POD_PASS=false
VITE_POD_REQUIRED_PASS=pod-ops-access
VITE_POD_USER_ROLE=role_pod_member

# ── Firebase phone OTP (same project as chronos-core/controls: caarya-moksha) ─
VITE_ENABLE_FIREBASE_AUTH=true
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=caarya-moksha.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=caarya-moksha
VITE_FIREBASE_STORAGE_BUCKET=caarya-moksha.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=

# ── Ask Moksha agent (optional, chirag-ai LLM proxy base) ─────────────────────
# When set with a valid token, Ask Moksha calls chirag-ai; otherwise it answers
# from a small built-in knowledge base (demo mode).
VITE_AI_URL=
